<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Style colors compile down to render-layer colors (one-way; DisplayList has no deps). -->
    <ProjectReference Include="..\Andy.Tui.DisplayList\Andy.Tui.DisplayList.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Exposes the test-only collision constructor for StyleCache identity tests. -->
    <InternalsVisibleTo Include="Andy.Tui.Style.Tests" />
  </ItemGroup>

</Project>
